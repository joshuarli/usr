set TERM screen

set PATH "$HOME/usr/bin:/opt/homebrew/opt/rustup/bin:$HOME/dev/tools/bin:$HOME/.local/bin:$HOME/.cargo/bin:$HOME/go/bin:/opt/homebrew/bin:$PATH"
set EDITOR $HOME/usr/bin/e
set PAGER less

# su=00:sg=00:ca=00 don't colorize setuid/gid or filecaps to avoid expensive syscalls
# or=40;31;01 broken symlinks are red
set LS_COLORS 'su=00:sg=00:ca=00:or=40;31;01:'

set XDG_CONFIG_HOME "$HOME/.config"
set XDG_CACHE_HOME "$HOME/.cache"
set XDG_DATA_HOME "$HOME/.local/share"

set HOMEBREW_NO_AUTO_UPDATE 1
set HOMEBREW_NO_INSTALLED_DEPENDENTS_CHECK 1
set HOMEBREW_NO_INSTALL_CLEANUP 1
set HOMEBREW_NO_ANALYTICS 1

set CARGO_NET_GIT_FETCH_WITH_CLI true

alias e $HOME/usr/bin/e

alias codx  codex --model gpt-5.4 --ask-for-approval never --sandbox workspace-write

alias p   /Applications/Play.app/Contents/MacOS/play

alias fd  fd --prune
alias fdh fd --prune --no-ignore-vcs -H -E '.git/'
alias rg  rg -S
alias rgh rg --hidden -S -g '!.git'
alias du  duf

alias pp  procs

alias syncthing syncthing serve --no-port-probing --no-browser --no-upgrade --gui-address='http://127.0.0.1:6969'
alias wol "$HOME/usr/bin/wol" '7c:83:34:bd:05:c4'
alias tu '/Applications/Tailscale.app/Contents/MacOS/Tailscale' up
alias td '/Applications/Tailscale.app/Contents/MacOS/Tailscale' down

alias grt cd "$(git rev-parse --show-toplevel)"

# git's diff (+delta) is way better than /usr/bin/diff
alias d   git diff --no-index

alias gaa git add --all
alias gcm git commit -m
alias gd  git d
alias gdd git diff --name-only --diff-filter=U
alias gdc git dc
alias gl  git l
alias gp  git push -u
alias grv git remote -v
alias gs  git status -sb
alias gss git status -sb -uall

alias tl tmux -f "$XDG_CONFIG_HOME/tmux/tmux.conf" ls
alias tn tmux -f "$XDG_CONFIG_HOME/tmux/tmux.conf" new -s
alias ta tmux -f "$XDG_CONFIG_HOME/tmux/tmux.conf" a -t
alias tk tmux -f "$XDG_CONFIG_HOME/tmux/tmux.conf" kill-session -t

# work
# set PATH "$HOME/.local/share/sentry-devenv/bin:$PATH"
set PATH "/opt/homebrew/share/google-cloud-sdk/bin:$PATH"
