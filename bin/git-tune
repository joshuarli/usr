#!/usr/bin/env bash
set -euo pipefail

readonly VERSION="1.0.0"
readonly GIT=/opt/homebrew/bin/git
readonly MIN_GIT_VERSION="2.53.0"

# --- Colors (respect NO_COLOR / non-TTY) ---

if [[ -z "${NO_COLOR:-}" ]] && [[ -t 1 ]]; then
  readonly BOLD=$'\033[1m' DIM=$'\033[2m'
  readonly RED=$'\033[31m' GREEN=$'\033[32m' YELLOW=$'\033[33m' BLUE=$'\033[34m'
  readonly RESET=$'\033[0m'
else
  readonly BOLD="" DIM="" RED="" GREEN="" YELLOW="" BLUE="" RESET=""
fi

# --- Globals ---

DRY_RUN=false

# --- Helpers ---

info()    { printf "\n%s==>%s %s%s\n" "$BLUE" "$BOLD" "$1" "$RESET"; }
success() { printf "  %s✓%s %s\n" "$GREEN" "$RESET" "$1"; }
warn()    { printf "  %s⚠%s %s\n" "$YELLOW" "$RESET" "$1"; }
error()   { printf "%serror:%s %s\n" "$RED" "$RESET" "$1" >&2; }
dim()     { printf "  %s%s%s\n" "$DIM" "$1" "$RESET"; }
die()     { error "$1"; exit 1; }


dry_run_print() {
  # Replace full git path with just "git" for readability
  local cmd="${*/$GIT/git}"
  dim "[dry-run] $cmd"
}

run() {
  if [[ "$DRY_RUN" == true ]]; then
    dry_run_print "$@"
    return 0
  fi
  "$@"
}

run_quiet() {
  if [[ "$DRY_RUN" == true ]]; then
    dry_run_print "$@"
    return 0
  fi
  "$@" 2>/dev/null || true
}

prompt_brew_install() {
  if [[ "$(uname)" == "Darwin" ]]; then
    if command -v brew &>/dev/null; then
      printf "  Install/upgrade via Homebrew? [y/N] "
      local answer
      IFS= read -r answer
      if [[ "$answer" =~ ^[Yy] ]]; then
        brew install git
        printf "\n%s✓%s Installed — please re-run git-tune\n" "$GREEN" "$RESET"
      else
        printf "  Run manually: brew install git\n"
      fi
    else
      printf "  Install: brew install git\n"
    fi
  fi
  exit 1
}

check_git_version() {
  if [[ ! -x "$GIT" ]]; then
    error "$GIT not found"
    prompt_brew_install
  fi

  local raw
  raw=$("$GIT" --version | awk '{print $3}')

  # Compare major.minor.patch numerically
  local -a got want
  IFS=. read -ra got <<< "$raw"
  IFS=. read -ra want <<< "$MIN_GIT_VERSION"
  for i in 0 1 2; do
    local g=${got[$i]:-0} w=${want[$i]:-0}
    if (( g < w )); then
      error "Git ${MIN_GIT_VERSION}+ required (found ${raw})"
      prompt_brew_install
    elif (( g > w )); then
      return 0
    fi
  done
}

default_branch() {
  # Try remote HEAD first
  local branch
  branch=$("$GIT" symbolic-ref refs/remotes/origin/HEAD 2>/dev/null) || true
  branch=${branch#refs/remotes/origin/}
  if [[ -n "$branch" ]]; then echo "$branch"; return; fi
  # Fall back to common names
  for name in main master; do
    if "$GIT" show-ref --verify --quiet "refs/heads/$name" 2>/dev/null; then
      echo "$name"; return
    fi
  done
  # Cannot determine default branch safely
  return 1
}

# --- Global Config ---

set_config() {
  local key="$1" value="$2"
  local current
  current=$("$GIT" config --global "$key" 2>/dev/null) || true
  if [[ "$current" == "$value" ]]; then
    success "$key = $value ${DIM}(already set)${RESET}"
  else
    run "$GIT" config --global "$key" "$value"
    success "$key = $value"
  fi
}

# apply_group LABEL DESCRIPTION key value [key value ...]
# In dry-run: displays the group without prompting.
# Otherwise: prompts y/N, applies on yes, skips on no.
apply_group() {
  local label="$1" desc="$2"
  shift 2
  local args=("$@")
  local i current all_set=true
  for (( i=0; i<${#args[@]}; i+=2 )); do
    current=$("$GIT" config --global "${args[i]}" 2>/dev/null) || true
    if [[ "$current" != "${args[i+1]}" ]]; then
      all_set=false
      break
    fi
  done
  if [[ "$all_set" == true ]]; then
    success "$label — already configured"
    return 0
  fi
  printf "\n  %s%s%s\n" "$BOLD" "$label" "$RESET"
  printf "  %s\n" "$desc"
  for (( i=0; i<${#args[@]}; i+=2 )); do
    dim "    ${args[i]} = ${args[i+1]}"
  done
  if [[ "$DRY_RUN" == true ]]; then
    return 0
  fi
  printf "  Apply? [y/N] "
  local answer
  IFS= read -r answer
  if [[ "$answer" =~ ^[Yy] ]]; then
    for (( i=0; i<${#args[@]}; i+=2 )); do
      set_config "${args[i]}" "${args[i+1]}"
    done
  else
    dim "  Skipped"
  fi
}

set_global_config() {
  info "Global git configuration"

  apply_group \
    "Commit graph" \
    "Caches commit metadata so git log, blame, and reachability queries skip object traversal. Updated automatically after gc and fetch." \
    core.commitGraph       true \
    gc.writeCommitGraph    true \
    fetch.writeCommitGraph true

  apply_group \
    "Filesystem performance" \
    "fsmonitor hooks into OS file-change notifications so git status only checks files the kernel flagged dirty. untrackedCache persists untracked-file scans between runs. preloadIndex and manyFiles enable threaded index loading. index v4 uses prefix compression." \
    core.fsmonitor      true \
    core.untrackedCache true \
    core.preloadIndex   true \
    feature.manyFiles   true \
    index.version       4

  apply_group \
    "Pack / repack" \
    "pack.threads 0 uses all CPU cores when packing. multiPackIndex maintains multiple pack files under one index. Bitmap indexes (writeBitmaps, writeBitmapHashCache) answer object reachability with bitwise ops, accelerating clone and fetch." \
    pack.threads              0 \
    core.multiPackIndex       true \
    repack.writeBitmaps       true \
    pack.writeBitmapHashCache true

  apply_group \
    "Parallel checkout" \
    "Writes working-tree files using a thread pool (0 = all cores) instead of serially. Noticeably faster on large checkouts, especially over network-backed storage." \
    checkout.workers 0

  apply_group \
    "Diff algorithm" \
    "Histogram diff (an improvement on patience) produces more readable hunks by preferring unique lines as split points. Usually better than Myers for source code." \
    diff.algorithm histogram

  apply_group \
    "Rerere" \
    "Records how you resolved each merge conflict. On future merges that produce the same conflict, git rerere reapplies the recorded resolution automatically." \
    rerere.enabled true

  apply_group \
    "Transfer safety" \
    "Validates every received object during fetch and push, catching corruption or malformed history early. May reject fetches from repos that already have fsck issues." \
    transfer.fsckObjects true

  apply_group \
    "Network" \
    "protocol.version 2 uses the faster Git wire protocol (server-side ref filtering, fewer round-trips). fetch.parallel 0 fetches all remotes simultaneously." \
    protocol.version 2 \
    fetch.parallel   0
}

# --- Repo Optimization ---

cleanup_common() {
  info "Pruning stale references"

  local remotes
  remotes=$("$GIT" remote 2>/dev/null) || true
  if [[ -n "$remotes" ]]; then
    while IFS= read -r remote; do
      run "$GIT" remote prune "$remote"
      success "Pruned remote: $remote"
    done <<< "$remotes"
  else
    dim "No remotes configured"
  fi

  run "$GIT" pack-refs --all
  success "Packed refs"

  run_quiet "$GIT" rerere gc
  success "Cleaned rerere cache"

  run_quiet "$GIT" worktree prune
  success "Pruned stale worktrees"
}

delete_merged_branches() {
  info "Deleting fully merged branches"

  local default current count=0
  default=$(default_branch) || { dim "Cannot determine default branch — skipping merged branch deletion"; return; }
  current=$("$GIT" branch --show-current 2>/dev/null) || current=""

  is_protected() {
    case "$1" in
      main|master|develop|development) return 0 ;;
    esac
    [[ -n "$current" && "$1" == "$current" ]] && return 0
    return 1
  }

  while IFS= read -r line; do
    # Skip current branch marker
    [[ "$line" == \** ]] && continue
    # Strip leading whitespace
    local branch=${line#"${line%%[![:space:]]*}"}
    [[ -z "$branch" ]] && continue
    is_protected "$branch" && continue
    run "$GIT" branch -d -- "$branch" >/dev/null
    success "Deleted: $branch"
    ((count++)) || true
  done < <("$GIT" branch --merged "$default" 2>/dev/null) || true

  if [[ $count -eq 0 ]]; then
    dim "No merged branches to delete"
  else
    success "Removed $count merged branch(es) total"
  fi
}

optimize_safe() {
  info "Checking repository integrity"
  run "$GIT" fsck --no-dangling --no-progress
  success "Repository integrity verified"

  cleanup_common

  info "Running garbage collection (safe)"
  run "$GIT" gc --quiet
  success "Garbage collection complete"
}

optimize_lossy() {
  info "Checking repository integrity"
  run "$GIT" fsck --no-dangling --no-progress
  success "Repository integrity verified"

  info "Expiring old reflogs (90-day threshold)"
  run "$GIT" reflog expire --expire=90.days --expire-unreachable=90.days --all
  success "Reflogs expired"

  delete_merged_branches
  cleanup_common

  info "Geometric repack"
  run "$GIT" repack -d --geometric=2 --no-write-bitmap-index --quiet
  success "Geometric repack complete"

  info "Pruning unreachable objects"
  run "$GIT" prune
  success "Unreachable objects pruned"
}

optimize_aggressive() {
  warn "Aggressive mode: this will purge all expendable data"

  info "Checking repository integrity"
  run "$GIT" fsck --no-dangling --no-progress
  success "Repository integrity verified"

  info "Expiring all reflogs"
  run "$GIT" reflog expire --expire=now --expire-unreachable=now --all
  success "All reflogs expired"

  delete_merged_branches
  cleanup_common

  info "Aggressive repack (depth=250, window=250 — may take a while)"
  run "$GIT" repack -Ad -f --depth=250 --window=250 --write-bitmap-index --quiet
  success "Aggressive repack complete"

  info "Pruning all unreachable objects"
  run "$GIT" prune --expire=now
  success "Unreachable objects pruned"
}

finalize() {
  info "Writing performance indexes"
  run "$GIT" commit-graph write --reachable --changed-paths
  success "Commit-graph written (with Bloom filters)"

  run_quiet "$GIT" multi-pack-index write --bitmap
  success "Multi-pack-index written (with bitmaps)"
}

# --- Plan & Confirm ---

print_plan() {
  local tier="$1" repo_root="$2"

  printf "\n%sgit-tune — %s mode%s\n" "$BOLD" "$tier" "$RESET"
  case "$tier" in
    safe)
      printf "Packs objects and runs standard gc. Nothing is permanently deleted unless\n"
      printf "it was already unreachable for more than 2 weeks.\n"
      ;;
    lossy)
      printf "Expires reflogs older than 90 days, deletes merged branches, and immediately\n"
      printf "prunes any objects that become unreachable as a result. Permanent.\n"
      ;;
    aggressive)
      printf "%sExpires the entire reflog immediately and purges all unreachable objects.\n"
      printf "Maximum compression, maximum data loss. Irreversible.%s\n" "$YELLOW" "$RESET"
      ;;
  esac

  if [[ -n "$repo_root" ]]; then
    printf "\n  %sRepository:%s %s\n" "$BOLD" "$RESET" "$repo_root"
    case "$tier" in
      safe)
        printf "    - fsck --no-dangling: verify object integrity (read-only)\n"
        printf "    - remote prune: drop tracking refs for deleted upstream branches\n"
        printf "    - pack-refs --all: consolidate loose refs into packed-refs\n"
        printf "    - rerere gc / worktree prune: clear stale resolution and worktree records\n"
        printf "    - gc: expire reflogs >90d reachable / >30d unreachable,\n"
        printf "          pack loose objects, prune unreachable objects older than 2 weeks\n"
        ;;
      lossy)
        printf "    - fsck --no-dangling: verify object integrity (read-only)\n"
        printf "    - reflog expire --expire=90.days: drop reflog entries older than 90 days\n"
        printf "    - branch -d: delete local branches fully merged into default branch\n"
        printf "    - remote prune / pack-refs --all / rerere gc / worktree prune\n"
        printf "    - repack -d --geometric=2: incrementally repack without a full rewrite\n"
        printf "    - prune: immediately remove all objects unreachable after reflog expiry\n"
        ;;
      aggressive)
        printf "    - fsck --no-dangling: verify object integrity (read-only)\n"
        printf "    %s- reflog expire --expire=now: discard the entire reflog immediately%s\n" "$YELLOW" "$RESET"
        printf "    - branch -d: delete local branches fully merged into default branch\n"
        printf "    - remote prune / pack-refs --all / rerere gc / worktree prune\n"
        printf "    %s- repack -Ad --depth=250 --window=250: full repack, may take a while%s\n" "$YELLOW" "$RESET"
        printf "    %s- prune --expire=now: discard all unreachable objects immediately%s\n" "$YELLOW" "$RESET"
        ;;
    esac
    printf "    - commit-graph write --changed-paths: build Bloom-filter traversal cache\n"
    printf "    - multi-pack-index write --bitmap: unified index + bitmaps across all packs\n"
  else
    printf "\n  %sRepository:%s (not inside a git repo — will be skipped)\n" "$BOLD" "$RESET"
  fi
}

confirm() {
  printf "\n  Proceed? [y/N] "
  local answer
  IFS= read -r answer
  [[ "$answer" =~ ^[Yy] ]] || { printf "Aborted.\n"; exit 0; }
}

# --- Main ---

usage() {
  cat <<'EOF'
git-tune — Optimize git repositories and configure global settings

Usage: git-tune [OPTIONS]

Tiers:
  --safe          Safe optimizations, no data loss (default)
  --lossy         Expire old reflogs (90d), delete merged branches
  --aggressive    Maximum compression, purge all expendable data

Options:
  --dry-run       Show what would be done without executing
  --globals-only  Only set global git config, skip repo optimization
  --no-globals    Skip global config, only optimize repo
  -h, --help      Show this help message
  --version       Show version
EOF
}

main() {
  local tier="safe"
  local globals=true
  local repo=true

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --safe)         tier="safe"; shift ;;
      --lossy)        tier="lossy"; shift ;;
      --aggressive)   tier="aggressive"; shift ;;
      --dry-run)      DRY_RUN=true; shift ;;
      --globals-only) globals=true; repo=false; shift ;;
      --no-globals)   globals=false; repo=true; shift ;;
      --version)      echo "git-tune $VERSION"; exit 0 ;;
      -h|--help)      usage; exit 0 ;;
      *)              die "Unknown option: $1" ;;
    esac
  done

  check_git_version

  # Determine repo context up front so the plan can reference it
  local repo_root=""
  if [[ "$repo" == true ]]; then
    if "$GIT" rev-parse --is-inside-work-tree &>/dev/null; then
      repo_root=$("$GIT" rev-parse --show-toplevel)
    elif [[ "$globals" == false ]]; then
      die "Not in a git repository"
    fi
  fi

  if [[ "$repo" == true ]]; then
    if [[ "$DRY_RUN" == true ]]; then
      printf "\n%s[dry-run mode — no changes will be made]%s\n" "$YELLOW" "$RESET"
      print_plan "$tier" "$repo_root"
    else
      print_plan "$tier" "$repo_root"
      confirm
    fi
  fi

  local start=$SECONDS

  # Repo optimization first
  if [[ "$repo" == true ]]; then
    if [[ -z "$repo_root" ]]; then
      warn "Not in a git repository — skipping repo optimization"
    else
      printf "\n%sgit-tune:%s optimizing %s %s(%s)%s\n" \
        "$BOLD" "$RESET" "$repo_root" "$DIM" "$tier" "$RESET"

      case "$tier" in
        safe)       optimize_safe ;;
        lossy)      optimize_lossy ;;
        aggressive) optimize_aggressive ;;
      esac

      finalize
    fi
  fi

  # Global config last (interactive, so repo work runs uninterrupted)
  if [[ "$globals" == true ]]; then
    set_global_config
  fi

  printf "%sDone in %ds%s\n" "$GREEN" "$(( SECONDS - start ))" "$RESET"
}

main "$@"
