#!/bin/sh
"$HOME/usr/py/.venv/bin/python" -m yt_dlp --ignore-config --ignore-errors \
    --remote-components 'ejs:github' \
    --js-runtimes node:/opt/homebrew/bin/node \
    -f 'bv*+ba/b' \
    --write-subs --write-auto-subs --sub-langs "orig" --sub-format srt --convert-subs srt \
    --add-metadata \
    --embed-thumbnail \
    --embed-metadata \
    --merge-output-format mp4 \
    -o '%(title)s [%(id)s].%(ext)s' "$@"

