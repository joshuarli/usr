#!/bin/sh
# Walk through branch commits one by one, oldest first.
# Uses merge-base to find where the branch diverges from the default remote branch.

set -eu

if [ $# -gt 0 ]; then
    base=$1
elif git rev-parse --verify main >/dev/null 2>&1; then
    base=main
elif git rev-parse --verify master >/dev/null 2>&1; then
    base=master
else
    echo "Could not find main or master branch. Specify a base branch." >&2
    exit 1
fi

merge_base=$(git merge-base "$base" HEAD)
commits=$(git rev-list --reverse "$merge_base"..HEAD)

if [ -z "$commits" ]; then
    echo "No commits between $base and HEAD."
    exit 0
fi

total=$(echo "$commits" | wc -l | tr -d ' ')
esc=$(printf '\033')
cr=$(printf '\r')
saved_tty=$(stty -g </dev/tty)
trap 'stty "$saved_tty" </dev/tty' EXIT INT TERM

read_key() {
    stty -icanon -echo </dev/tty
    c=$(dd bs=1 count=1 </dev/tty 2>/dev/null)
    case "$c" in
        "$esc")
            rest=$(dd bs=2 count=1 </dev/tty 2>/dev/null)
            c="$c$rest" ;;
        [0-9])
            while true; do
                next=$(dd bs=1 count=1 </dev/tty 2>/dev/null)
                case "$next" in [0-9]) c="$c$next" ;; *) break ;; esac
            done ;;
    esac
    stty "$saved_tty" </dev/tty
    printf '%s' "$c"
}

i=1

while [ "$i" -ge 1 ] && [ "$i" -le "$total" ]; do
    sha=$(echo "$commits" | sed -n "${i}p")
    echo "--- commit $i/$total ---"
    git show "$sha"
    printf '\n[j/Enter/\xe2\x86\x92] next  [k/\xe2\x86\x90] prev  [0-9] jump  [q] quit: '
    input=$(read_key)
    echo
    case "$input" in
        q|Q) exit 0 ;;
        k|K|p|P|"${esc}[A"|"${esc}[D") [ "$i" -gt 1 ] && i=$((i - 1)) ;;
        j|J|n|N|"$cr"|''|"${esc}[B"|"${esc}[C") i=$((i + 1)) ;;
        *[0-9]*)
            if [ "$input" -ge 1 ] 2>/dev/null && [ "$input" -le "$total" ]; then
                i=$input
            else
                echo "Invalid: must be 1-$total"
            fi ;;
    esac
done
